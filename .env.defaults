# ---------------------------------------------------------------------------
# ForgeCore Newsletter Engine — environment defaults
# Copy to .env and fill in real values. Never commit .env to git.
# ---------------------------------------------------------------------------

# --- LLM models (OpenAI API only) ---
# Local Ollama is intentionally not used by the production pipeline.
RESEARCH_MODEL=gpt-4o-mini
WRITER_MODEL=gpt-4o-mini
EDITOR_MODEL=gpt-4o-mini
CRITIC_MODEL=gpt-4o-mini
FALLBACK_MODEL=gpt-4o-mini
OPENAI_RETRIES=3
MAX_CONTEXT_CHARS=22000

# --- Content pipeline ---
AUTO_REPAIR_PATHS=1
MIN_CRITIC_OVERALL=6.5
MIN_CRITIC_CATEGORY=6.0
CRITIC_MAX_REWRITE_ITEMS=6
MAX_TARGETED_REWRITE_ITEMS=6
MAX_ARTICLES_PER_RUN=12
MAX_FEED_ITEMS_PER_SOURCE=12

# --- Site ---
SITE_DOMAIN=news.forgecore.co
SITE_BASE_URL=https://news.forgecore.co
NEWSLETTER_NAME=ForgeCore AI Productivity Brief
NEWSLETTER_TAGLINE=Practical AI workflows, tools, and ROI cases for operators
TARGET_AUDIENCE=Operators, founders, consultants, and technical teams adopting AI workflows.
SPONSOR_EMAIL=sponsors@forgecore.co

# --- Subscribe CTA ---
PRIMARY_CTA_TEXT=Subscribe for weekly operator-grade AI workflows
PRIMARY_CTA_URL=https://forgecore-newsletter.beehiiv.com/

# --- Kit (formerly ConvertKit) ---
# KIT_API_KEY         = Settings > Developer > API Key  (keep in .env / GitHub secrets)
# KIT_FORM_ID         = Forms > your form > embed URL number
# KIT_BROADCAST_TAG   = Tag ID to send broadcasts to (optional)
# KIT_FROM_NAME       = Display name shown to subscribers
# KIT_REPLY_TO        = Reply-to email address
# KIT_SEND_MODE       = public (auto-send) | draft
KIT_API_KEY=
KIT_FORM_ID=
KIT_BROADCAST_TAG=
KIT_FROM_NAME=ForgeCore
KIT_REPLY_TO=sponsors@forgecore.co
KIT_SEND_MODE=draft

# --- Cloudflare ---
CLOUDFLARE_PAGES_PROJECT=forgecore-newsletter
ENABLE_CLOUDFLARE_DEPLOY=0
