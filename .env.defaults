# ---------------------------------------------------------------------------
# FORGE/DAILY — environment defaults
# Copy to .env and fill in real values. Never commit .env to git.
# ---------------------------------------------------------------------------

# --- LLM models (local Ollama) ---
OLLAMA_URL=http://localhost:11434
RESEARCH_MODEL=qwen2.5:14b-instruct
WRITER_MODEL=gemma3:12b
EDITOR_MODEL=gemma3:12b
CRITIC_MODEL=gemma3:12b
FALLBACK_MODEL=qwen3:8b
MAX_CONTEXT_CHARS=22000
OLLAMA_TIMEOUT=300
OLLAMA_RETRIES=3

# --- Content pipeline ---
AUTO_REPAIR_PATHS=1
MIN_CRITIC_OVERALL=8.0
MIN_CRITIC_CATEGORY=7.0
CRITIC_MAX_REWRITE_ITEMS=6
MAX_TARGETED_REWRITE_ITEMS=6
MAX_ARTICLES_PER_RUN=8
MAX_FEED_ITEMS_PER_SOURCE=8

# --- Site ---
SITE_DOMAIN=news.forgecore.co
SITE_BASE_URL=https://news.forgecore.co
NEWSLETTER_NAME=FORGE/DAILY
NEWSLETTER_TAGLINE=AI news for people who don't need it explained twice.
TARGET_AUDIENCE=Developers, technical builders, and AI-forward operators.
SPONSOR_EMAIL=sponsors@forgecore.co

# --- Subscribe CTA (points to Kit landing page or form) ---
PRIMARY_CTA_TEXT=Subscribe free
PRIMARY_CTA_URL=https://forge-daily.kit.com/

# --- Kit (formerly ConvertKit) ---
# KIT_API_KEY         = Settings > Developer > API Key  (keep in .env / GitHub secrets)
# KIT_FORM_ID         = Forms > your form > embed URL number
# KIT_BROADCAST_TAG   = Tag ID to send broadcasts to (optional)
# KIT_FROM_NAME       = Display name shown to subscribers
# KIT_REPLY_TO        = Reply-to email address
# KIT_SEND_MODE       = public (auto-send) | draft
KIT_API_KEY=
KIT_FORM_ID=
KIT_BROADCAST_TAG=
KIT_FROM_NAME=Em @ FORGE/DAILY
KIT_REPLY_TO=em@forgecore.co
KIT_SEND_MODE=draft

# --- Cloudflare ---
CLOUDFLARE_PAGES_PROJECT=forgecore-newsletter
ENABLE_CLOUDFLARE_DEPLOY=1
