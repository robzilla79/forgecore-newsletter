---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import LatestNews from '../../components/LatestNews.astro';
---
<BaseLayout title="Proof | ForgeCore" description="Artifacts, updates, and visible proof from the ForgeCore system.">
  <section class="section">
    <div class="container">
      <SectionHeader eyebrow="Proof" title="Evidence over adjectives." description="ForgeCore should prove seriousness through visible outputs, changelog discipline, and public artifacts." />
      <LatestNews />
      <div class="cta-band" style="margin-top:2rem;">
        <h3>Proof rules</h3>
        <p>No fake case studies. No speculative wins. No ornamental metrics. Publish artifacts, changes, and real learnings.</p>
      </div>
    </div>
  </section>
</BaseLayout>
