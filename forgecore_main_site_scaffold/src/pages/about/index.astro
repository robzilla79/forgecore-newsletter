---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
---
<BaseLayout title="About | ForgeCore" description="What ForgeCore is building and why it is being built in public.">
  <section class="section">
    <div class="reading">
      <SectionHeader eyebrow="About" title="ForgeCore is building a resilient financial instrument." description="The goal is not to ship trend content. The goal is to build a system that discovers opportunity, creates assets, deploys monetization, measures outcomes, and compounds." />
      <div class="prose">
        <p>ForgeCore exists to build deterministic revenue architecture that can survive changing platforms, changing tools, and changing conditions.</p>
        <p>It is public because public artifacts create pressure for discipline, proof, and operational honesty.</p>
        <p>Read the <a href="/about/manifesto">manifesto</a> for the full doctrine.</p>
      </div>
    </div>
  </section>
</BaseLayout>
