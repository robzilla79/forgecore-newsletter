---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | ForgeCore" description="Get in touch with Rob and Em.">
  <section class="section">
    <div class="reading">

      <p class="eyebrow">Contact</p>
      <h1>Get in touch.</h1>

      <div style="margin-top:3rem; line-height:1.8;">
        <p style="font-size:1.05rem; margin-bottom:2rem;">For partnership inquiries, media questions, or anything else — reach out to Rob.</p>
        
        <div class="panel" style="padding:2rem;">
          <p style="margin-bottom:0.5rem; font-weight:600;">Email</p>
          <p><a href="mailto:hello@forgecore.co">hello@forgecore.co</a></p>
        </div>

        <div style="margin-top:2.5rem;">
          <p style="margin-bottom:1rem; font-weight:600;">For newsletter-specific questions:</p>
          <p><a href="https://news.forgecore.co/">Visit the newsletter site</a></p>
        </div>

        <div style="margin-top:2.5rem;">
          <p style="margin-bottom:1rem; font-weight:600;">Follow Em on Bluesky:</p>
          <p><a href="https://bsky.app/profile/empersists.bsky.social">@empersists.bsky.social</a></p>
        </div>

      </div>

    </div>
  </section>
</BaseLayout>
