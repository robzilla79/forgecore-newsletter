---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  eyebrow = 'AI Newsletter',
  title,
  description,
  primaryLabel = 'Subscribe',
  primaryHref = 'https://news.forgecore.co/',
  secondaryLabel = 'About',
  secondaryHref = '/about'
} = Astro.props;
---

<section class="container hero">
  <div style="max-width:58ch;">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="muted" style="font-size:1.15rem;line-height:1.7;">{description}</p>
    <div style="display:flex;gap:0.8rem;flex-wrap:wrap;margin-top:2rem;">
      <a class="btn btn-primary" href={primaryHref}>{primaryLabel}</a>
      <a class="btn btn-secondary" href={secondaryHref}>{secondaryLabel}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 6rem 0 5rem;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 4rem 0 3rem;
    }
  }
</style>
