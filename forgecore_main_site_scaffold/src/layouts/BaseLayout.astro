---
import { navItems, site } from '../data';

interface Props {
  title?: string;
  description?: string;
}
const { title = site.title, description = site.description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-soft: #f8fafc;
        --text: #0f172a;
        --text-soft: #475569;
        --border: #e2e8f0;
        --accent: #ea580c;
        --accent-soft: #fff7ed;
        --container: 1160px;
        --reading: 72ch;
        --radius: 18px;
        --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
      }
      a { color: inherit; text-decoration: none; }
      p, li { color: var(--text-soft); }
      h1, h2, h3, h4 { line-height: 1.08; letter-spacing: -0.02em; margin: 0 0 0.8rem; }
      h1 { font-size: clamp(2.4rem, 5vw, 4.8rem); }
      h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); }
      h3 { font-size: 1.2rem; }
      .container { width: min(calc(100% - 2rem), var(--container)); margin: 0 auto; }
      .reading { width: min(calc(100% - 2rem), var(--reading)); margin: 0 auto; }
      .eyebrow {
        display: inline-block;
        margin-bottom: 0.8rem;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-weight: 800;
        color: var(--accent);
      }
      .header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(12px);
        background: rgba(255,255,255,0.9);
        border-bottom: 1px solid var(--border);
      }
      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 0;
      }
      .brand {
        display: inline-flex;
        gap: 0.75rem;
        align-items: center;
        font-weight: 800;
      }
      .brand-mark {
        display: inline-grid;
        place-items: center;
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        background: var(--accent);
        color: #fff;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 1rem;
        border-radius: 999px;
        border: 1px solid transparent;
        font-weight: 700;
      }
      .btn-primary { background: var(--accent); color: #fff; }
      .btn-secondary { background: #fff; color: var(--text); border-color: var(--border); }
      .section { padding: 5rem 0; }
      .hero {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 2rem;
        padding: 5rem 0 4rem;
        align-items: end;
      }
      .card, .panel {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        background: #fff;
      }
      .panel { padding: 1.5rem; }
      .muted { color: var(--text-soft); }
      .grid-2, .grid-3, .grid-4 {
        display: grid;
        gap: 1rem;
      }
      .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .grid-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
      .list-clean {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .cta-band {
        background: var(--accent-soft);
        border: 1px solid #fed7aa;
        border-radius: var(--radius);
        padding: 1.75rem;
      }
      .footer {
        border-top: 1px solid var(--border);
        padding: 2rem 0 3rem;
        margin-top: 3rem;
      }
      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 2rem;
      }
      .prose p + p { margin-top: 1rem; }
      .prose ul { padding-left: 1.1rem; }
      .meta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        color: #64748b;
        font-size: 0.95rem;
      }
      @media (max-width: 920px) {
        .hero, .grid-2, .grid-3, .grid-4, .footer-inner { grid-template-columns: 1fr; display: grid; }
        .nav { align-items: start; }
      }
    </style>
  </head>
  <body>
    <header class="header">
      <div class="container nav">
        <a class="brand" href="/">
          <span class="brand-mark">F</span>
          <span>ForgeCore</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          <a class="btn btn-primary" href="https://news.forgecore.co/">Subscribe</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="container footer-inner">
        <div>
          <a class="brand" href="/">
            <span class="brand-mark">F</span>
            <span>ForgeCore</span>
          </a>
          <p class="muted">A deterministic, self-improving autonomous revenue system.</p>
        </div>
        <nav class="nav-links" aria-label="Footer">
          <a href="/about/manifesto">Manifesto</a>
          <a href="/proof/changelog">Changelog</a>
          <a href="/contact">Contact</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="https://news.forgecore.co/">Newsletter</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
